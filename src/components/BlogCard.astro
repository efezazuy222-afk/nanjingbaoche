---
import { Icon } from "astro-icon/components";
const { post } = Astro.props;
---
<article class="blog-card">
  <a class="blog-image" href={`/blogs/${post.id}/`}><img src={post.data.cover} alt={post.data.title} loading="lazy" /></a>
  <div class="blog-content">
    <div class="blog-meta"><span>{post.data.category}</span><span><Icon name="bi:calendar-event" />{post.data.date}</span></div>
    <h2><a href={`/blogs/${post.id}/`}>{post.data.title}</a></h2>
    <p>{post.data.description}</p>
    <a class="blog-link" href={`/blogs/${post.id}/`}>阅读全文 <Icon name="bi:arrow-right" /></a>
  </div>
</article>
<style>
  .blog-card { border-bottom: 1px solid #d8d3c7; }
  .blog-image { display: block; aspect-ratio: 16/10; overflow: hidden; border-radius: 7px; }
  .blog-image img { width: 100%; height: 100%; object-fit: cover; transition: transform .45s ease; }
  .blog-card:hover img { transform: scale(1.035); }
  .blog-content { padding: 17px 2px 22px; }
  .blog-meta { display: flex; gap: 13px; color: #777d78; font-size: .76rem; }
  .blog-meta span { display: inline-flex; align-items: center; gap: 5px; }
  .blog-meta span:first-child { color: #a33a2b; font-weight: 800; }
  h2 { margin: 9px 0 8px; font-family: Georgia,"Songti SC",serif; font-size: 1.28rem; line-height: 1.45; }
  p { margin: 0; color: #626963; font-size: .88rem; line-height: 1.7; }
  .blog-link { display: inline-flex; align-items: center; gap: 7px; margin-top: 13px; color: #315848; font-size: .84rem; font-weight: 800; }
</style>
