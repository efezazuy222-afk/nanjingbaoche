---
import { Icon } from "astro-icon/components";
import { site } from "@src/config";
---

<footer>
  <div class="container footer-grid">
    <div class="footer-intro">
      <div class="footer-brand">澜青旅行社</div>
      <p>熟悉南京，也懂旅行节奏。澜青旅行社为家庭、朋友小团和商务客户提供干净舒适、沟通省心的南京及江苏周边包车服务。</p>
    </div>
    <div><h2>快速入口</h2><a href="/tours">包车线路</a><a href="/blogs">南京攻略</a><a href="/about">关于我们</a><a href="/contact">联系咨询</a></div>
    <div><h2>热门服务</h2><a href="/#services">禄口机场接送</a><a href="/#services">南京南站接送</a><a href="/#services">家庭旅游包车</a><a href="/#services">商务会议用车</a></div>
    <div><h2>联系我们</h2><a href={`tel:${site.phone}`}><Icon name="bi:telephone" /> {site.phone}</a><a href={`tel:${site.mobileLink}`}><Icon name="bi:telephone" /> {site.mobile}</a><a href={`mailto:${site.email}`}><Icon name="bi:envelope" /> {site.email}</a></div>
  </div>
  <div class="container footer-bottom"><span>© 2026 澜青旅行社</span><span><a href="/privacy">隐私政策</a> · <a href="/terms">服务条款</a></span></div>
</footer>

<style>
  footer { padding: 64px 0 24px; background: #1d2722; color: white; }
  .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1.15fr 1.4fr; gap: 42px; }
  .footer-brand { font-family: Georgia,"Songti SC",serif; font-size: 2rem; }
  .footer-intro p { max-width: 440px; color: #b9c2bd; line-height: 1.8; }
  h2 { margin: 6px 0 18px; font-size: .95rem; }
  a { display: block; margin: 11px 0; color: #c9d0cc; font-size: .88rem; }
  a:hover { color: white; }
  .footer-bottom { display: flex; justify-content: space-between; margin-top: 44px; padding-top: 20px; border-top: 1px solid rgba(255,255,255,.12); color: #97a39d; font-size: .8rem; }
  .footer-bottom a { display: inline; }
  @media (max-width: 820px) { .footer-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 520px) { .footer-grid { grid-template-columns: 1fr; gap: 24px; } .footer-bottom { align-items: flex-start; flex-direction: column; gap: 8px; } }
</style>
