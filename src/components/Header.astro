---
import { Icon } from "astro-icon/components";
import { site } from "@src/config";
const pathname = Astro.url.pathname;
const nav = [
  ["首页", "/"],
  ["包车线路", "/tours"],
  ["用车服务", "/#services"],
  ["南京攻略", "/blogs"],
  ["关于我们", "/about"],
  ["联系咨询", "/contact"],
];
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="南京包车首页">
      <span class="brand-mark">宁</span>
      <span><strong>{site.name}</strong><small>本地司机 · 定制出行</small></span>
    </a>
    <nav class="desktop-nav" aria-label="主导航">
      {nav.map(([label, href]) => <a class:list={[pathname === href || (href !== "/" && pathname.startsWith(href)) ? "active" : ""]} href={href}>{label}</a>)}
    </nav>
    <a class="header-phone" href={`tel:${site.phone}`}><Icon name="bi:telephone" />{site.phone}</a>
    <details class="mobile-menu">
      <summary aria-label="打开导航"><Icon name="bi:list" /></summary>
      <nav>{nav.map(([label, href]) => <a href={href}>{label}</a>)}</nav>
    </details>
  </div>
</header>

<style>
  .site-header { position: sticky; top: 0; z-index: 50; border-bottom: 1px solid rgba(24,32,29,.1); background: rgba(246,244,239,.96); backdrop-filter: blur(14px); }
  .header-inner { height: 74px; display: flex; align-items: center; gap: 28px; }
  .brand { display: flex; align-items: center; gap: 11px; min-width: 180px; }
  .brand-mark { display: grid; place-items: center; width: 38px; height: 38px; border-radius: 4px; background: #a33a2b; color: white; font-family: Georgia,"Songti SC",serif; font-size: 1.25rem; }
  .brand strong, .brand small { display: block; letter-spacing: 0; }
  .brand strong { font-size: 1.05rem; }
  .brand small { margin-top: 2px; color: #707770; font-size: .68rem; }
  .desktop-nav { display: flex; align-items: center; justify-content: center; gap: 24px; margin-left: auto; }
  .desktop-nav a { position: relative; font-size: .9rem; font-weight: 650; white-space: nowrap; }
  .desktop-nav a:hover, .desktop-nav a.active { color: #a33a2b; }
  .header-phone { display: inline-flex; align-items: center; gap: 8px; padding: 10px 13px; border: 1px solid #a33a2b; border-radius: 5px; color: #8d3024; font-size: .88rem; font-weight: 750; white-space: nowrap; }
  .mobile-menu { display: none; margin-left: auto; position: relative; }
  .mobile-menu summary { display: grid; place-items: center; width: 42px; height: 42px; list-style: none; cursor: pointer; font-size: 1.5rem; }
  .mobile-menu summary::-webkit-details-marker { display: none; }
  .mobile-menu nav { position: absolute; top: 50px; right: 0; width: 210px; padding: 8px; border: 1px solid #d8d3c7; border-radius: 6px; background: #fffefa; box-shadow: 0 18px 45px rgba(24,32,29,.16); }
  .mobile-menu nav a { display: block; padding: 12px; border-bottom: 1px solid #eee9df; font-weight: 650; }
  @media (max-width: 980px) { .desktop-nav, .header-phone { display: none; } .mobile-menu { display: block; } }
</style>
