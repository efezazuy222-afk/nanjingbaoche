---
import { Icon } from "astro-icon/components";
import { site } from "@src/config";
---

<form id="inquiry-form" class="inquiry-form">
  <div class="form-head"><span>告诉我们您的计划</span><strong>1分钟快速询价</strong><p>先确认需求再报价，不收定金也能咨询。</p></div>
  <div class="form-grid">
    <label>称呼<input name="name" required placeholder="怎么称呼您" /></label>
    <label>联系电话<input name="phone" required inputmode="tel" placeholder="手机号或微信号" /></label>
    <label>出发日期<input name="date" type="date" /></label>
    <label>出行人数<input name="people" type="number" min="1" placeholder="例如：5" /></label>
    <label>用车类型<select name="service"><option>南京市内包车</option><option>机场/高铁接送</option><option>南京周边包车</option><option>商务会议用车</option><option>其他需求</option></select></label>
    <label>车型偏好<select name="vehicle"><option>请司机推荐</option><option>5座轿车</option><option>7座商务车</option><option>9-19座中巴</option><option>大巴</option></select></label>
  </div>
  <label>行程需求<textarea name="message" rows="4" placeholder="请写下接送地点、想去的景点、行李数量等"></textarea></label>
  <button class="btn btn-primary" type="submit"><Icon name="bi:send" />生成咨询邮件</button>
  <a class="direct-call" href={`tel:${site.phone}`}>也可直接拨打 {site.phone}</a>
</form>

<script define:vars={{ email: site.email }}>
  document.querySelector('#inquiry-form')?.addEventListener('submit', (event) => {
    event.preventDefault();
    const form = event.currentTarget;
    const data = new FormData(form);
    const lines = ['南京包车询价', ...Array.from(data.entries()).map(([key, value]) => `${key}: ${value || '未填写'}`)];
    window.location.href = `mailto:${email}?subject=${encodeURIComponent('南京包车行程询价')}&body=${encodeURIComponent(lines.join('\n'))}`;
  });
</script>

<style>
  .inquiry-form { padding: 30px; border: 1px solid #ddd6c9; border-radius: 8px; background: #fffefa; box-shadow: 0 18px 50px rgba(50,46,38,.09); }
  .form-head span { color: #a33a2b; font-size: .8rem; font-weight: 800; }
  .form-head strong { display: block; margin-top: 5px; font-family: Georgia,"Songti SC",serif; font-size: 1.7rem; }
  .form-head p { margin: 7px 0 22px; color: #69706a; font-size: .88rem; }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
  label { display: block; color: #4d554f; font-size: .82rem; font-weight: 700; }
  input, select, textarea { width: 100%; margin-top: 7px; padding: 12px 13px; border: 1px solid #d8d3c7; border-radius: 5px; background: #fbfaf6; color: #18201d; outline: none; }
  input:focus, select:focus, textarea:focus { border-color: #a33a2b; box-shadow: 0 0 0 3px rgba(163,58,43,.08); }
  textarea { resize: vertical; }
  .inquiry-form > label { margin-top: 15px; }
  button { width: 100%; margin-top: 16px; }
  .direct-call { display: block; margin-top: 13px; text-align: center; color: #315848; font-size: .86rem; font-weight: 750; }
  @media (max-width: 560px) { .inquiry-form { padding: 22px; } .form-grid { grid-template-columns: 1fr; } }
</style>
