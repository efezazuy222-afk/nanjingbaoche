---
import MainLayout from "@src/layouts/MainLayout.astro";
import { faqs } from "@src/data/faqs";
const faqSchema={"@type":"FAQPage",mainEntity:faqs.map(([question,answer])=>({"@type":"Question",name:question,acceptedAnswer:{"@type":"Answer",text:answer}}))};
---
<MainLayout title="南京包车常见问题｜价格、车型与行程调整" description="关于南京包车价格、接送机、儿童座椅、路线调整及费用包含的常见问题。" schema={faqSchema}>
  <section class="page-head"><div class="container"><span>服务说明</span><h1>常见问题</h1><p>预订之前，把容易忽略的细节先说清楚。</p></div></section>
  <section class="section"><div class="container faq-list">{faqs.map(([q,a],i)=><details open={i===0}><summary>{q}</summary><p>{a}</p></details>)}</div></section>
</MainLayout>
<style>.page-head{padding:80px 0 60px;background:#e6e1d7}.page-head span{color:#a33a2b;font-weight:800}.page-head h1{margin:8px 0;font-family:Georgia,"Songti SC",serif;font-size:clamp(2.8rem,6vw,5rem)}.faq-list{max-width:850px}.faq-list details{border-bottom:1px solid #d3cdc1}.faq-list summary{padding:22px 0;cursor:pointer;font-size:1.05rem;font-weight:800}.faq-list p{max-width:760px;margin:0 0 22px;color:#616963;line-height:1.8}</style>
