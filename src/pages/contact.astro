---
import MainLayout from "@src/layouts/MainLayout.astro";
import InquiryForm from "@src/components/InquiryForm.astro";
import { Icon } from "astro-icon/components";
import { site } from "@src/config";
const { noindex = false, canonicalPath } = Astro.props;
---
<MainLayout title="联系澜青旅行社｜免费咨询南京包车" description="向澜青旅行社提交南京包车日期、人数和线路需求，或拨打400-858-0518、15250969678咨询。" noindex={noindex} canonicalPath={canonicalPath}>
  <section class="contact-page section"><div class="container contact-grid"><div><span class="section-kicker">免费咨询</span><h1 class="section-title">把日期和人数<br/>告诉我们就够了</h1><p>路线还没想好也没关系。我们可以根据住宿位置、同行人员和返程安排，先给您一个顺路的建议。</p><div class="contact-lines"><a href={`tel:${site.phone}`}><Icon name="bi:telephone"/><span>咨询热线<strong>{site.phone}</strong></span></a><a href={`tel:${site.mobileLink}`}><Icon name="bi:telephone"/><span>手机联系<strong>{site.mobile}</strong></span></a><a href={`mailto:${site.email}`}><Icon name="bi:envelope"/><span>电子邮箱<strong>{site.email}</strong></span></a></div></div><InquiryForm/></div></section>
</MainLayout>
<style>.contact-page{min-height:70vh;background:#e9e5dc}.contact-grid{display:grid;grid-template-columns:.85fr 1.15fr;gap:70px;align-items:start}.contact-grid>div>p{max-width:470px;color:#5f6761;line-height:1.9}.contact-lines{display:grid;margin-top:30px}.contact-lines a{display:flex;align-items:center;gap:14px;padding:16px 0;border-bottom:1px solid #ccc5b9}.contact-lines :global(svg){color:#a33a2b}.contact-lines span{color:#6a716c;font-size:.78rem}.contact-lines strong{display:block;margin-top:4px;color:#18201d;font-size:1rem}@media(max-width:820px){.contact-grid{grid-template-columns:1fr}}</style>
